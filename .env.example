OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_TITLE=SmartWiki2

WIKI_VAULT_PATH=
WIKI_VAULT_GIT_URL=git@github.com:ljohri/wiki_vault.git
SMARTWIKI_ENV=dev
# Local dev: paths relative to SmartWiki2 repo root (Docker WORKDIR /app resolves the same layout).
SMARTWIKI_SITE_DIR=./site
SMARTWIKI_QUARTZ_DIR=publisher/quartz
SMARTWIKI_LOG_LEVEL=INFO
